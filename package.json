{
  "name": "@lordierclaw/bluenote",
  "version": "0.0.0",
  "description": "Official BlueNote distribution CLI.",
  "license": "MIT",
  "bin": {
    "bluenote": "./dist/bin.js",
    "bn": "./dist/bin.js"
  },
  "engines": {
    "node": ">=16.14 <17 || >=18"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node tests/run-tests.js",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@lordierclaw/bluenote-core": "git+https://github.com/LordierClaw/bluenote-core.git#826914e2ef865aafa0c9cdcabfb362a0e43850d1"
  },
  "devDependencies": {
    "@types/node": "16.18.126",
    "typescript": "5.8.3"
  }
}

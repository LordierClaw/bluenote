{
  "name": "@lordierclaw/bluenote",
  "version": "0.1.0",
  "description": "Official BlueNote distribution CLI.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "bin": {
    "bluenote": "./dist/bin.js",
    "bn": "./dist/bin.js"
  },
  "engines": {
    "node": ">=16.14 <17 || >=18"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/bin.js', 0o755)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node tests/run-tests.js",
    "version:status": "node scripts/version-status.mjs",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@lordierclaw/bluenote-core": "git+https://github.com/LordierClaw/bluenote-core.git#a942cd17e1d3df7947b8f9198672f04165ef179a"
  },
  "devDependencies": {
    "@types/node": "16.18.126",
    "typescript": "5.8.3"
  }
}
